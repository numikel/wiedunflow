# WiedunFlow configuration — copy to `tutorial.config.yaml` in your repo root
# Precedence: CLI flags > env vars (WIEDUNFLOW_*) > --config <path> >
#             ./tutorial.config.yaml > ~/.config/wiedunflow/config.yaml > defaults.

llm:
  provider: openai             # openai (default) | anthropic | openai_compatible | custom
  model_plan: gpt-5.4          # planning Stage 4 (single LessonManifest call)
  model_narrate: gpt-5.4       # narration Stage 5/6 (sequential, full prior-lesson context)
  concurrency: 10              # cap 20; used from S4 (Stage 5/6 parallel calls)
  max_retries: 5               # tenacity attempts on RateLimitError (429)
  max_wait_s: 60               # backoff ceiling per attempt
  # api_key: set via OPENAI_API_KEY env var (recommended) — do NOT commit secrets
  # For Anthropic BYOK: set provider: anthropic + ANTHROPIC_API_KEY.
  # base_url: optional override for openai_compatible / custom endpoints.
  #   Only http(s) schemes are accepted. Cloud-metadata hosts
  #   (169.254.169.254, metadata.google.internal, 100.100.100.200, fd00:ec2::*)
  #   are HARD-REJECTED to prevent SSRF (key + source code exfiltration).
  #   Private RFC1918 addresses (e.g. http://192.168.1.5:11434/v1 for Ollama
  #   on a LAN host) trigger a stderr warning but are allowed.
  #   The consent banner is shown for ALL non-None base_url setups; bypass
  #   with --yes / --no-consent-prompt.
  # base_url: http://localhost:11434/v1   # Ollama / LM Studio / vLLM

# Ingestion — additive over .gitignore
exclude_patterns:
  - "**/tests/**"
  - "**/migrations/**"
include_patterns: []

# Planning
max_lessons: 30                # hard cap per FR-35
# v0.4.0+: 5-level enum (noob | junior | mid | senior | expert).
# Old free-text values are auto-mapped via fuzzy substring match (shim removed in v1.0).
target_audience: mid

# Output (optional — default `./wiedunflow-<repo>.html` in the current directory)
# Relative paths resolve against the cwd at runtime; absolute paths are used
# verbatim. Override at the CLI with `--output PATH` / `-o PATH`.
# output_path: ./wiedunflow-<repo>.html
# output_path: ./reports/wiedunflow-${repo}.html   # any path you like

# Security (Sprint 6 / v0.0.6)
# Hard-refuse list (.env*, *.pem, id_rsa, credentials.*, ...) excludes matching
# files from ingestion regardless of include/exclude. The only escape hatch is
# this allow-list — add filenames explicitly to keep them in the tutorial.
security:
  allow_secret_files: []         # e.g. [".env.example"] to include dotenv docs

# Tutorial quality (v0.2.1) — opt-in controls; defaults preserve v0.2.0 behaviour.
planning:
  # auto = move entry-point lesson to position 1 if detected (main/CLI/__main__/@click.command)
  # always = enforce; raise if no entry point detected
  # never = preserve raw leaves->roots ordering from the LLM planner
  entry_point_first: auto
  # When true, lessons whose primary code_ref is <3 lines AND not cited as primary
  # elsewhere AND not an entry point AND not in top-5% PageRank are dropped from
  # the manifest and folded into a "Helper functions" appendix on the closing lesson.
  skip_trivial_helpers: false

narration:
  # Word-count floor for 1-line primary code refs (other tiers stay at 80/220/350).
  # Lower this to allow tighter narration for one-liner helpers.
  min_words_trivial: 50
  # When true, narration markdown ```python code blocks are validated against the
  # source_excerpt of each code_ref; signature mismatches trigger a 1-shot retry
  # with an explicit hint. Set to false to bypass validation entirely.
  snippet_validation: true
