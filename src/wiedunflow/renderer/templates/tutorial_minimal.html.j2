<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ repo_name }} — CodeGuide Tutorial</title>
  <style>
    /* Minimal walking skeleton styles — pixel-perfect design comes in Sprint 5 */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; display: flex; flex-direction: column; height: 100vh; overflow: hidden; color: #1a1a1a; background: #fff; }
    .banner-degraded {
      background: #fff3cd;
      border-bottom: 2px solid #e6a817;
      color: #7a4f00;
      padding: 10px 24px;
      font-size: 0.92em;
      font-weight: 600;
      text-align: center;
      flex-shrink: 0;
    }
    #app { display: flex; flex: 1; overflow: hidden; }
    #sidebar { width: 220px; min-width: 220px; border-right: 1px solid #e0e0e0; overflow-y: auto; padding: 16px 0; background: #fafafa; }
    #sidebar h2 { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #666; padding: 0 16px 8px; }
    #sidebar ul { list-style: none; }
    #sidebar li button { display: block; width: 100%; text-align: left; padding: 8px 16px; font-size: 14px; border: none; background: none; cursor: pointer; color: #333; }
    #sidebar li button:hover, #sidebar li button.active { background: #e8e8e8; font-weight: 600; }
    #sidebar li button.skipped-nav { color: #999; font-style: italic; }
    #main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    #lesson-content { flex: 1; overflow-y: auto; padding: 32px 40px; max-width: 800px; }
    #lesson-content h1 { font-size: 24px; margin-bottom: 16px; }
    #lesson-content p { line-height: 1.7; margin-bottom: 12px; }
    #nav { display: flex; gap: 8px; padding: 12px 40px; border-top: 1px solid #e0e0e0; }
    #nav button { padding: 6px 16px; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background: #fff; font-size: 14px; }
    #nav button:disabled { opacity: 0.4; cursor: default; }
    #footer { text-align: center; font-size: 11px; color: #999; padding: 8px; border-top: 1px solid #e0e0e0; flex-shrink: 0; }
    .code-block { background: #f5f5f5; border: 1px solid #ddd; border-radius: 4px; padding: 12px; overflow-x: auto; font-size: 13px; margin: 12px 0; }
    .codeguide-banner { padding: 8px 12px; margin: 12px 0; border-radius: 4px; font-size: 0.9em; }
    .codeguide-banner--warn { background: #ffe8b3; color: #a15c00; }
    .codeguide-banner--info { background: #e3f0ff; color: #245a9e; }
    /* US-031: Skipped lesson placeholder */
    .lesson-skipped {
      border: 2px dashed #ccc;
      border-radius: 6px;
      padding: 32px 24px;
      margin: 24px 0;
      background: repeating-linear-gradient(
        -45deg,
        #fafafa,
        #fafafa 6px,
        #f0f0f0 6px,
        #f0f0f0 12px
      );
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      text-align: center;
    }
    .lesson-skipped__pill {
      display: inline-block;
      background: #888;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 12px;
    }
    .lesson-skipped__message {
      color: #666;
      font-size: 0.92em;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  {% if degraded %}
  <div class="banner-degraded" role="alert">
    &#9888; Tutorial DEGRADED: {{ skipped_count }} of {{ total_planned }} lessons skipped
  </div>
  {% endif %}
  <div id="app">
    <aside id="sidebar">
      <h2>Lessons</h2>
      <ul id="lesson-list"></ul>
    </aside>
    <div id="main">
      <div id="lesson-content">
        <h1 id="lesson-title"></h1>
        <div id="lesson-narrative"></div>
      </div>
      <nav id="nav">
        <button id="btn-prev" class="prev" disabled>&#8592; Previous</button>
        <button id="btn-next" class="next">Next &#8594;</button>
      </nav>
      <footer id="footer">
        {% if doc_coverage and doc_coverage.is_low %}
        <div class="codeguide-banner codeguide-banner--warn" role="status">
          &#9888; Documentation coverage is low ({{ (doc_coverage.ratio * 100) | round(0, 'floor') | int }}%).
          Some lessons may reference symbols with limited context.
        </div>
        {% endif %}
        {% if not has_readme %}
        <div class="codeguide-banner codeguide-banner--info" role="status">
          &#8505; No README found &mdash; repository-level context may be limited in narrations.
        </div>
        {% endif %}
        Generated by <strong>CodeGuide {{ codeguide_version }}</strong>
        from <code>{{ repo_branch }}@{{ repo_commit_hash[:7] }}</code>
        at {{ generated_at }}
        &nbsp;&middot;&nbsp; Offline &mdash; no external resources
        {% if skipped_count > 0 %}
        &nbsp;&middot;&nbsp; {{ skipped_count }} skipped
        {% endif %}
      </footer>
    </div>
  </div>

  <script type="application/json" id="tutorial-data">{{ tutorial_data_json | safe }}</script>

  <script>
    (function() {
      var raw = document.getElementById('tutorial-data').textContent;
      var data = JSON.parse(raw);
      var lessons = data.lessons;
      var current = 0;

      var listEl = document.getElementById('lesson-list');
      var titleEl = document.getElementById('lesson-title');
      var narrativeEl = document.getElementById('lesson-narrative');
      var btnPrev = document.getElementById('btn-prev');
      var btnNext = document.getElementById('btn-next');

      function renderSkippedLesson(lesson) {
        var section = document.createElement('section');
        section.className = 'lesson-skipped';
        section.setAttribute('data-lesson-id', lesson.id);
        var pill = document.createElement('span');
        pill.className = 'lesson-skipped__pill';
        pill.textContent = 'SKIPPED';
        var msg = document.createElement('p');
        msg.className = 'lesson-skipped__message';
        msg.textContent = lesson.narrative || 'This lesson was skipped due to grounding failures.';
        section.appendChild(pill);
        section.appendChild(msg);
        return section;
      }

      function renderLesson(idx) {
        var lesson = lessons[idx];
        titleEl.textContent = lesson.title;
        if (lesson.is_skipped) {
          narrativeEl.innerHTML = '';
          narrativeEl.appendChild(renderSkippedLesson(lesson));
        } else {
          narrativeEl.innerHTML = lesson.narrative_html || lesson.narrative.replace(/\n/g, '<br>');
        }
        btnPrev.disabled = idx === 0;
        btnNext.disabled = idx === lessons.length - 1;
        listEl.querySelectorAll('button').forEach(function(btn, i) {
          btn.classList.toggle('active', i === idx);
        });
        current = idx;
        try { localStorage.setItem('codeguide:last-lesson', String(idx)); } catch(e) {}
      }

      lessons.forEach(function(lesson, idx) {
        var li = document.createElement('li');
        var btn = document.createElement('button');
        btn.textContent = (idx + 1) + '. ' + lesson.title;
        if (lesson.is_skipped) {
          btn.className = 'skipped-nav';
        }
        btn.addEventListener('click', function() { renderLesson(idx); });
        li.appendChild(btn);
        listEl.appendChild(li);
      });

      btnPrev.addEventListener('click', function() { if (current > 0) renderLesson(current - 1); });
      btnNext.addEventListener('click', function() { if (current < lessons.length - 1) renderLesson(current + 1); });

      var saved = 0;
      try { saved = parseInt(localStorage.getItem('codeguide:last-lesson') || '0', 10) || 0; } catch(e) {}
      renderLesson(Math.min(saved, lessons.length - 1));
    })();
  </script>
</body>
</html>
