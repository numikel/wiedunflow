  CodeGuide tutorial.html.j2 — Sprint 5 pixel-perfect template.
  Structural freeze contract (see ADR-0009):
    DOM IDs: #tutorial-progress, #tutorial-topbar, #tutorial-sidebar,
             #tutorial-narration, #tutorial-splitter, #tutorial-code,
             #tutorial-footer, #tweaks-panel
    JSON envelope: tutorial-meta, tutorial-clusters, tutorial-lessons
    JS API: window.CodeGuide.init() on DOMContentLoaded.

  ADR-0011 binary decisions enforced: A1 Paper + Inter + Direction A + Modern CLI.
-#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ repo_name }} — CodeGuide Tutorial</title>
  <style>
{{ tokens_css | safe }}
{{ tutorial_css | safe }}
  </style>
</head>
<body>
  <div id="tutorial-progress" aria-hidden="true"><span></span></div>

  <header id="tutorial-topbar">
    <div class="brand" aria-hidden="true">C</div>
    <div class="title">CodeGuide</div>
    <div class="breadcrumb">{{ repo_name }}
      {%- if run_status == "degraded" %} · <span>DEGRADED</span>{% endif -%}
    </div>
    <div class="nav-group" role="group" aria-label="Lesson navigation">
      <button id="tutorial-prev" class="nav-btn" type="button" aria-label="Previous lesson" disabled>&#8592; Prev</button>
      <span id="tutorial-progress-label" class="progress-label" aria-live="polite"></span>
      <button id="tutorial-next" class="nav-btn" type="button" aria-label="Next lesson" disabled>Next &#8594;</button>
    </div>
    <button id="tweaks-open" class="icon-btn" aria-label="Tutorial tweaks" type="button">&#9881;</button>
  </header>

  {% if run_status == "degraded" %}
  <div class="tutorial-degraded-banner" role="status">
    &#9888; {{ skipped_count }} of {{ total_planned }} lessons skipped — grounding failed
  </div>
  {% endif %}

  <div id="tutorial-app">
    <aside id="tutorial-sidebar" aria-label="Table of contents">
      <div class="repo-header">{{ repo_name }}</div>
    </aside>

    <div id="tutorial-content">
      <main id="tutorial-narration" aria-live="polite">
        <div id="tutorial-narration-body"></div>
      </main>
      <div id="tutorial-splitter" role="separator" aria-orientation="vertical" aria-label="Resize panels"></div>
      <aside id="tutorial-code" aria-label="Code reference">
        <div id="tutorial-code-head" class="code-head">(select a lesson)</div>
        <div id="tutorial-code-body" class="code-body"></div>
      </aside>
    </div>

    <footer id="tutorial-footer">
      <div class="meta">
        <span>Generated by CodeGuide {{ codeguide_version }} (Apache 2.0) &mdash; this document is fully offline.</span>
        <span class="meta-sep">{{ repo_branch }}@{{ repo_commit_hash[:7] }}</span>
        <span class="meta-sep">{{ generated_at }}</span>
        {% if doc_coverage is not none %}
        <span class="meta-sep">Jedi {{ (doc_coverage.ratio * 100) | round(0, 'floor') | int }}%</span>
        {% endif %}
      </div>
    </footer>
  </div>

  <div id="tweaks-panel" role="dialog" aria-label="Tutorial tweaks">
    <h3>Tweaks</h3>
    <div class="row">
      <div class="label">Theme</div>
      <div class="seg" role="group" aria-label="Theme">
        <button type="button" data-theme-set="light">Light</button>
        <button type="button" data-theme-set="dark">Dark</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="tutorial-meta">{{ meta_json | safe }}</script>
  <script type="application/json" id="tutorial-clusters">{{ clusters_json | safe }}</script>
  <script type="application/json" id="tutorial-lessons">{{ lessons_json | safe }}</script>

  <script>
{{ tutorial_js | safe }}
  </script>
  <script>
    (function () {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () { window.CodeGuide.init(); });
      } else {
        window.CodeGuide.init();
      }
    })();
  </script>
</body>
</html>
