# CodeGuide — environment variables template
# Copy to `.env` (gitignored) or export in your shell.
# Precedence: CLI flags > env vars > --config file > ./tutorial.config.yaml > user config > defaults
# Full schema: see `src/codeguide/cli/config.py` (CodeguideConfig).

# ---------------------------------------------------------------------------
# BYOK — API keys (exactly ONE required for the chosen provider)
# ---------------------------------------------------------------------------

# Anthropic (default provider). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alt provider). Required when CODEGUIDE_LLM_PROVIDER=openai or openai_compatible.
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# CodeGuide runtime configuration (CODEGUIDE_* prefix; maps to CodeguideConfig fields)
# ---------------------------------------------------------------------------

# Provider: anthropic | openai | openai_compatible | custom
# CODEGUIDE_LLM_PROVIDER=anthropic

# Model routing — Haiku for parallel leaf descriptions, Opus for narration (D2 eval).
# CODEGUIDE_LLM_MODEL_PLAN=claude-sonnet-4-6
# CODEGUIDE_LLM_MODEL_NARRATE=claude-opus-4-7

# For "custom" or "openai_compatible" providers (Ollama / LM Studio / vLLM):
# CODEGUIDE_LLM_BASE_URL=http://localhost:11434/v1
# CODEGUIDE_LLM_API_KEY_ENV=OLLAMA_API_KEY     # name of env var holding the key

# Concurrency (default 10, hard cap 20 per FR-67).
# CODEGUIDE_LLM_CONCURRENCY=10

# Retry / backoff tuning.
# CODEGUIDE_LLM_MAX_RETRIES=5
# CODEGUIDE_LLM_MAX_WAIT_S=60

# Tutorial shape (FR-35 hard cap 30).
# CODEGUIDE_MAX_LESSONS=30
# CODEGUIDE_TARGET_AUDIENCE="mid-level Python developer"

# ---------------------------------------------------------------------------
# Editor resolver (US-016 `--review-plan`) — first match wins.
# ---------------------------------------------------------------------------

# EDITOR=vim
# VISUAL=code

# ---------------------------------------------------------------------------
# Release gate (`pytest -m eval`, US-064). Skip rubric archive check if set.
# ---------------------------------------------------------------------------

# CODEGUIDE_SKIP_RUBRIC_GATE=1

# ---------------------------------------------------------------------------
# Security posture (US-011)
# ---------------------------------------------------------------------------
# CodeGuide transmits source code ONLY to the configured LLM provider endpoint.
# No telemetry, no analytics, no third-party network calls.
# See README.md "Privacy disclosure" and docs/adr/0010-secret-redaction-zero-telemetry.md
